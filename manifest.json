{
   "action": {
      "default_icon": {
         "128": "images/icon128.png"
      },
      "default_popup": "popup.html"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "*://*.youtube.com/*" ]
   } ],
   "description": "Only allow videos from your favorite channels and block YouTube Shorts. Stay Focused!",
   "key": "",
   "manifest_version": 3,
   "name": "YouTube Productivity Filter - Block Distractions & Filter Channels",
   "permissions": [ "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.0.0"
}
